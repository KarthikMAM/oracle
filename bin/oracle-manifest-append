#!/usr/bin/env bash
# Append a JSON line to the task's manifest, enforcing the RITE invariant
# (artifact path referenced in the entry MUST exist on disk before append).
#
# Usage:
#   oracle-manifest-append <task-id> '<json-object>'
#
# Concurrency: uses mkdir-as-lock (portable across macOS/Linux).

set -euo pipefail

# lock_is_stale <lock-dir> <ttl-seconds> — true only for a confirmed orphan: the recorded
# holder PID is dead, OR its acquire-epoch is older than the TTL (PID-reuse backstop), OR the
# pid file is absent AND the dir mtime is older than the TTL (a holder killed in the tiny
# window between mkdir and the pid write). A live or just-acquired lock is never stale.
lock_is_stale() {
    local lock="$1" ttl="$2" held holder acquired now mtime
    now=$(date +%s)
    held=$(cat "${lock}/pid" 2>/dev/null || echo "")
    holder="${held%% *}"
    acquired="${held##* }"
    if [[ -z "${holder}" ]]; then
        mtime=$(stat -f %m "${lock}" 2>/dev/null || stat -c %Y "${lock}" 2>/dev/null || echo "${now}")
        (( now - mtime > ttl ))
        return
    fi
    if ! kill -0 "${holder}" 2>/dev/null; then
        return 0
    fi
    if [[ "${acquired}" =~ ^[0-9]+$ ]] && (( now - acquired > ttl )); then
        return 0
    fi
    return 1
}

if [[ $# -ne 2 ]]; then
    echo "usage: oracle-manifest-append <task-id> '<json-object>'" >&2
    exit 2
fi

TASK_ID="$1"
JSON="$2"

ROOT="${HOME}/.oracle/runs/${TASK_ID}"
MANIFEST="${ROOT}/manifest.jsonl"
LOCK="${MANIFEST}.lock"

mkdir -p "${ROOT}"

# Validate JSON.
if ! echo "${JSON}" | python3 -c 'import json,sys; json.loads(sys.stdin.read())' 2>/dev/null; then
    echo "oracle-manifest-append: invalid JSON" >&2
    exit 3
fi

# Enforce RITE: if "artifact" is present and non-null, the file must exist.
artifact=$(echo "${JSON}" | python3 -c '
import json, sys
obj = json.loads(sys.stdin.read())
print(obj.get("artifact") or "")
')

if [[ -n "${artifact}" ]]; then
    if [[ ! -e "${artifact}" ]]; then
        echo "oracle-manifest-append: RITE violation — artifact does not exist: ${artifact}" >&2
        exit 4
    fi
fi

# Acquire mkdir-lock. The hot path is a plain atomic mkdir spin — fast and race-free.
# Staleness reclaim is deliberately kept OUT of the hot path: reading lock metadata and acting
# on it is never atomic with the dir's identity (a classic mkdir-lock TOCTOU), so doing it on
# every contended iteration corrupts the lock under load. Instead, only AFTER the full spin
# ceiling elapses — which in practice happens only when a holder was killed by SIGKILL/OOM/
# power-loss and left an orphan (the EXIT trap handles every normal release) — do we attempt a
# single guarded reclaim and then resume spinning. This recovers the bus for the run and its
# resume without ever racing a live holder.
LOCK_TTL_SECONDS=120
attempts=0
reclaim_tried=0
while ! mkdir "${LOCK}" 2>/dev/null; do
    attempts=$((attempts + 1))
    if [[ ${attempts} -gt 600 ]]; then
        if (( reclaim_tried == 0 )) && lock_is_stale "${LOCK}" "${LOCK_TTL_SECONDS}"; then
            # One-shot reclaim of a confirmed-orphan lock: rename then drop, so two racers
            # cannot both delete-and-recreate the same dir.
            if mv "${LOCK}" "${LOCK}.stale.$$" 2>/dev/null; then
                rm -rf "${LOCK}.stale.$$"
            fi
            reclaim_tried=1
            attempts=0
            continue
        fi
        echo "oracle-manifest-append: lock contention timeout on ${LOCK}" >&2
        exit 5
    fi
    sleep 0.05
done
trap 'rm -rf "${LOCK}" 2>/dev/null || true' EXIT
echo "$$ $(date +%s)" > "${LOCK}/pid"

echo "${JSON}" >> "${MANIFEST}"
